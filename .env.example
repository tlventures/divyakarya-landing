# ── Firebase (client-side, VITE_ prefix required) ────────────────────────────
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ── Google Sheets (server-side, set in Vercel dashboard) ──────────────────────
# Service account email from the JSON key file (client_email field)
GOOGLE_SERVICE_ACCOUNT_EMAIL=divyakarya@your-project.iam.gserviceaccount.com
# Service account private key — paste the full value including -----BEGIN...-----
# Vercel stores it with literal \n; the API route converts them automatically.
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
# The spreadsheet ID — found in the sheet URL:
# https://docs.google.com/spreadsheets/d/<SHEET_ID>/edit
GOOGLE_SHEET_ID=your_spreadsheet_id_here
